# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brandlens?schema=public"

# Comma-separated registry of adapters to enable. Unknown ids are ignored.
ENABLED_MODELS="openai,gemini,claude"

# OpenAI adapter settings.
OPENAI_API_KEY="sk-your-openai-key"
OPENAI_MODEL="gpt-4o-mini"

# Gemini adapter settings.
# Note: the requested @google/generative-ai SDK was archived by Google on December 16, 2025,
# but this scaffold supports it because it is part of your stated stack.
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-1.5-flash"

# Anthropic Claude adapter settings.
CLAUDE_API_KEY="your-anthropic-api-key"
CLAUDE_MODEL="claude-3-5-haiku-20241022"
